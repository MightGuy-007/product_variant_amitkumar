<odoo>
    <record id="product_variant_form_view" model="ir.ui.view">
        <field name="name">product_variant_form_view</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="after">
                <page name="Part specification">
                    <group>
                        <group>
                            <field name="is_multi_parts"/>
                            <field name="total_cost"/>
                        </group>

                        <separator/>

                        <group invisible="is_multi_parts">
                            <field name="material_id"/>

                            <field name="surface_finish_id"/>

                            <field name="uv_printing_id"/>

                            <field name="color_shade_id"/>
                        </group>

                    </group>
                    <notebook>
                        <page>
                            <field name="parts_lines_ids" invisible="not is_multi_parts">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="unit_cost"/>
                                    <field name="component_cost"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </page>
            </xpath>
        </field>
    </record>
</odoo>